meta {
  name: 02 - Register (New User)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "{{newUsername}}",
    "password": "{{newPassword}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body && res.body.token) {
    bru.setEnvVar("userToken", res.body.token);
  }
}

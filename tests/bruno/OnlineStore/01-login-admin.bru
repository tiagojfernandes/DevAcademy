meta {
  name: 01 - Login (Admin)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{adminUsername}}",
    "password": "{{adminPassword}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body && res.body.token) {
    bru.setEnvVar("adminToken", res.body.token);
  }
}

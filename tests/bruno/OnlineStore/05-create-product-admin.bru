meta {
  name: 05 - Create Product (Admin)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "name": "Bruno Test Product",
    "description": "Created from the Bruno collection",
    "price": 19.99,
    "sku": "BRUNO-001",
    "stockQuantity": 50,
    "categoryId": {{categoryId}}
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.id) {
    bru.setEnvVar("productId", res.body.id);
  }
}
